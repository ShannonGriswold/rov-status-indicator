#:kivy 1.9

#:include colors.kv

BoxLayout:
  orientation: 'vertical'
  BoxLayout:
    orientation: 'horizontal'
    Label:
      text: app.arm_text
      text_size: self.size
      size_hint_x: 0.75
      halign: 'left'
      valign: 'middle'
      padding_x: dp(10)
      font_size: sp(20)
    Label:
      size_hint_y: 0.25
      size_hint_x:0.25
      pos_hint: {'center_x':0.5, 'center_y':0.5}
      canvas:
        Color: 
          rgba: green if app.armed else red
        Ellipse:
          size: (self.size[1], self.size[1])
          pos: self.pos
  BoxLayout:
    orientation: 'horizontal'
    Button:
      text: "Arm"
      on_press: app.send_arm()
      background_color: green
      font_size: sp(20)
    Button:
      text: "Disarm"
      on_press: app.send_disarm()
      background_color: red
      font_size: sp(20)
